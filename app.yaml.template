command:
  - gunicorn
  - app:app
env:
  - name: HOME
    value: /app/python/source_code
  - name: DATABRICKS_TOKEN
    valueFrom: DATABRICKS_TOKEN
  - name: ANTHROPIC_MODEL
    value: databricks-claude-opus-4-6
  - name: GEMINI_MODEL
    value: databricks-gemini-3-1-pro
  - name: CLAUDE_CODE_DISABLE_AUTO_MEMORY
    value: 0
